parameters:
	ignoreErrors:
		-
			message: '#^Method App\\Events\\TranscriptionSegmentCreated\:\:broadcastWith\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: app/Events/TranscriptionSegmentCreated.php

		-
			message: '#^Method App\\Http\\Middleware\\LogTranscriptionAccess\:\:handle\(\) has no return type specified\.$#'
			identifier: missingType.return
			count: 1
			path: app/Http/Middleware/LogTranscriptionAccess.php

		-
			message: '#^Method App\\Mail\\InvoiceIssuedMail\:\:attachments\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: app/Mail/InvoiceIssuedMail.php

		-
			message: '#^Class App\\Models\\InvoiceItem uses generic trait Illuminate\\Database\\Eloquent\\Factories\\HasFactory but does not specify its types\: TFactory$#'
			identifier: missingType.generics
			count: 1
			path: app/Models/InvoiceItem.php

		-
			message: '#^Class App\\Models\\ProfessionalProfile uses generic trait Illuminate\\Database\\Eloquent\\Factories\\HasFactory but does not specify its types\: TFactory$#'
			identifier: missingType.generics
			count: 1
			path: app/Models/ProfessionalProfile.php

		-
