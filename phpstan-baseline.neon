			count: 1
			path: app/Models/User.php

		-
			message: '#^Method App\\Notifications\\InvoiceOverdueNotification\:\:via\(\) return type has no value type specified in iterable type array\.$#'
			identifier: missingType.iterableValue
			count: 1
			path: app/Notifications/InvoiceOverdueNotification.php

		-
