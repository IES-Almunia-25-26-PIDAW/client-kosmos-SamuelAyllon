        "@types/node": "^22.13.5",
        "@vitest/ui": "^3.2.5",
        "babel-plugin-react-compiler": "^1.0.0",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.0.1",
        "eslint-import-resolver-typescript": "^4.4.5",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-react": "^7.37.3",
        "eslint-plugin-react-hooks": "^7.0.0",
        "jsdom": "^29.1.1",
