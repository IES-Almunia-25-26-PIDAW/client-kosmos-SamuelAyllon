# ==============================================================================
# .env.prod.example — Variables de entorno para deploy/docker-compose.prod.yml
# ==============================================================================
# Copia este archivo a .env.prod y rellena los valores reales.
#
#   cp .env.prod.example .env.prod
#   nano .env.prod
#
# NUNCA committear .env.prod (ya está en .gitignore).
# ==============================================================================

# ── Dominio público (DuckDNS) ─────────────────────────────────────────────────
# Subdominio gratuito en https://www.duckdns.org
# Ejemplo: si registras "clientkosmos" → DOMAIN=clientkosmos.duckdns.org
DOMAIN=clientkosmos.duckdns.org
DUCKDNS_SUBDOMAIN=clientkosmos
DUCKDNS_TOKEN=replace-with-duckdns-token

# ── ACME / Let's Encrypt ──────────────────────────────────────────────────────
# Email para notificaciones de expiración del certificado.
ACME_EMAIL=samuelayllonsevilla86@gmail.com

# ── Imagen Docker ─────────────────────────────────────────────────────────────
# Cambia a un SHA específico para fijar versión (ej. APP_TAG=8838488).
APP_TAG=latest

# ── Laravel ───────────────────────────────────────────────────────────────────
# Genera una vez con:
#   docker run --rm samue45/client-kosmos:latest php artisan key:generate --show
# y pégala aquí. Si se cambia, todas las sesiones activas se invalidan.
APP_KEY=

APP_NAME=ClientKosmos

# ── Base de datos (MySQL) ─────────────────────────────────────────────────────
# Estos valores los consume el servicio `db` para crear el usuario y, en el
# servicio `app`, para conectarse. Cámbialos antes del primer arranque.
DB_PASSWORD=replace-with-strong-password
MYSQL_ROOT_PASSWORD=replace-with-strong-root-password

# ── Correo (SMTP real) ────────────────────────────────────────────────────────
# Usa un proveedor SMTP real en producción (Resend, Postmark, Mailgun, SES).
# Mailpit es solo para desarrollo.
MAIL_MAILER=smtp
MAIL_HOST=smtp.resend.com
MAIL_PORT=465
MAIL_USERNAME=resend
MAIL_PASSWORD=replace-with-smtp-token
MAIL_FROM_ADDRESS=noreply@clientkosmos.duckdns.org
MAIL_FROM_NAME=ClientKosmos

# ── IA contextual (Groq u OpenAI) ─────────────────────────────────────────────
# Sin esta clave la app funciona, pero las funciones Kosmo no estarán disponibles.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# ── Stripe (opcional, requerido para cobros a pacientes) ──────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── Google OAuth + Calendar (opcional) ────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://clientkosmos.duckdns.org/auth/google/callback
