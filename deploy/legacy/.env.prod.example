# ==============================================================================
# .env.prod.example — Variables de entorno para deploy en Railway
# ==============================================================================
# Pega estas variables en el panel de Railway (Service → Variables → Raw Editor).
#
# Reglas Railway:
#   - NO uses comillas alrededor de los valores (Railway las trata como literales).
#   - Las referencias entre servicios usan la sintaxis ${{Servicio.VAR}} SIN comillas.
#   - NO definas PORT; Railway lo inyecta automáticamente y tu contenedor debe
#     escuchar en $PORT.
#   - La interpolación tipo dotenv (${VAR}) NO funciona; usa ${{shared.VAR}} o
#     pon el valor literal.
# ==============================================================================

# ── Dominio público (Railway) ─────────────────────────────────────────────────
# Genera el dominio en Settings → Networking → Generate Domain.
# Si conectas dominio propio, sustituye la URL.
APP_URL=https://clientkosmos.up.railway.app
ASSET_URL=https://clientkosmos.up.railway.app

# ── Laravel ───────────────────────────────────────────────────────────────────
# Genera una vez con:  php artisan key:generate --show
# Si se cambia, todas las sesiones activas se invalidan.
APP_KEY=

APP_NAME=ClientKosmos
APP_ENV=production
APP_DEBUG=false
APP_LOCALE=es
APP_FALLBACK_LOCALE=en

BCRYPT_ROUNDS=12
LOG_CHANNEL=stderr
FILESYSTEM_DISK=local
TRUSTED_PROXIES=*

# ── Drivers (todos en database porque las tablas existen tras migrate) ────────
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ── Base de datos (MySQL plugin de Railway) ───────────────────────────────────
# Añade el plugin MySQL al proyecto y referencia sus variables (sin comillas).
DB_CONNECTION=mysql
DB_HOST=${{MySQL.MYSQLHOST}}
DB_PORT=${{MySQL.MYSQLPORT}}
DB_DATABASE=${{MySQL.MYSQLDATABASE}}
DB_USERNAME=${{MySQL.MYSQLUSER}}
DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# ── Correo (SMTP real) ────────────────────────────────────────────────────────
# Usa un proveedor SMTP real en producción (Resend, Postmark, Mailgun, SES).
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=ClientKosmos

# ── IA contextual (Groq u OpenAI) ─────────────────────────────────────────────
# Sin esta clave la app funciona, pero las funciones Kosmo no estarán disponibles.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# ── Stripe (opcional, requerido para cobros a pacientes) ──────────────────────
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ── Google OAuth + Calendar (opcional) ────────────────────────────────────────
# El redirect URI debe coincidir EXACTAMENTE con el dado de alta en Google Cloud
# y con el host de APP_URL.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://clientkosmos.up.railway.app/auth/google/callback
